# TMI Terraform Analyzer - Lambda Webhook Configuration Example
#
# Copy this file to terraform.tfvars and fill in the required values.
# Alternatively, use environment-specific files (environments/dev.tfvars, environments/prod.tfvars)

# AWS Configuration
aws_region  = "us-east-1"
environment = "dev" # dev, staging, or prod

# Domain Configuration
webhook_domain      = "webhook.tmi.dev"
route53_zone_id     = "Z0123456789ABCDEFGHIJ" # Replace with your Route 53 zone ID
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/abc-def-123" # Replace with your ACM certificate ARN

# Secrets Manager
secrets_manager_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:tmi-tf/oauth-credentials-AbCdEf"

# TMI Server
tmi_server_url = "https://api.tmi.dev"

# Lambda Configuration (defaults are production-ready)
receiver_lambda_memory              = 128
receiver_lambda_timeout             = 10
receiver_lambda_reserved_concurrency = 10

analyzer_lambda_memory              = 3008
analyzer_lambda_timeout             = 900 # 15 minutes
analyzer_lambda_reserved_concurrency = 5
analyzer_lambda_ephemeral_storage   = 2048 # 2GB

# SQS Configuration
sqs_visibility_timeout = 960 # 16 minutes (6x analyzer timeout)
sqs_max_receive_count  = 3

# DynamoDB Configuration
dynamodb_ttl_days = 7

# Monitoring
alarm_email        = "devops@example.com" # Email for CloudWatch alarms
enable_dlq_alarms  = true
enable_xray_tracing = true

# Canary Deployment (production only)
enable_canary = false
canary_weight = 0.1 # 10% of traffic to new version
