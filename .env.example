# TMI Server Configuration
TMI_SERVER_URL=https://api.tmi.dev
TMI_OAUTH_IDP=google

# LLM Provider Configuration
# Supported providers: anthropic, xai, gemini
LLM_PROVIDER=anthropic
# Optional model override (defaults: claude-sonnet-4-5, grok-beta, gemini-2.0-flash-exp)
# LLM_MODEL=claude-sonnet-4-5

# Anthropic (Claude) API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# x.ai (Grok) API Configuration (required if LLM_PROVIDER=xai)
# XAI_API_KEY=your_xai_api_key_here

# Google Cloud (Gemini) Configuration (required if LLM_PROVIDER=gemini)
# GCP_SERVICE_ACCOUNT_KEY={"type": "service_account", ...}
# GCP_PROJECT_ID=your_project_id
# GCP_LOCATION=us-central1

# GitHub API Configuration (optional - for higher rate limits)
GITHUB_TOKEN=your_github_token_here

# Application Settings
MAX_REPOS=3
CLONE_TIMEOUT=300
# Base names for notes and diagrams (model name will be appended automatically)
ANALYSIS_NOTE_NAME=Terraform Analysis Report
DIAGRAM_NAME=Infrastructure Data Flow Diagram
